//@version=5
indicator("Sav FX - Semi / Quarterly Cycles", overlay=false, max_boxes_count=500, shorttitle="Sav FX ", max_lines_count=500, max_labels_count=500)

ShowQuadrennialCyles  = input(true, title="Quadrennial Cycles", group="LTF Time Cycles") //6
ShowYearlyCyles  = input(true, title="Yearly Cycles", group="LTF Time Cycles") //6
ShowWeeklyCyles  = input(true, title="Weekly Cycles", group="LTF Time Cycles") //6
showDailyCycles = input(true, title="Daily Cycles", group="LTF Time Cycles") //5
show6HourCycles = input(true, title=" 6 Hour Cycles", group="LTF Time Cycles") //4
show90MinIntervals = input(true, title=" 90 Minute ", group="LTF Time Cycles") //3
show22_5MinIntervals = input(true, title=" 22.5 Minute ", group="LTF Time Cycles") //2
show5_625MinIntervals = input(true, title=" 5.5 Minute ", group="LTF Time Cycles") //1
 
use_dark_mode = input(false, title="Semi Cycles", group="Display Options")
show_labels = input(false, title="Show Labels", group="Display Options")

// Color definitions
color light_q1 = color.rgb(194, 198, 211)
color light_q2 = color.rgb(220, 195, 200)
color light_q3 = color.rgb(189, 210, 189)
color light_q4 = color.rgb(185, 194, 222)
color light_q5 = color.rgb(227, 228, 230, 100)
color light_q6 = color.rgb(194, 198, 211)
color light_q7 = color.rgb(185, 194, 222)

color dark_q1 = color.rgb(185, 194, 222)
color dark_q2 = color.rgb(194, 198, 211)
color dark_q3 = color.rgb(185, 194, 222)
color dark_q4 = color.rgb(194, 198, 211)
color dark_q5 = color.rgb(230, 230, 230, 97)
color dark_q6 = color.rgb(185, 194, 222)
color dark_q7 = color.rgb(194, 198, 211)

// Determine colors based on the selected mode
q1_color = use_dark_mode ? dark_q1 : light_q1
q2_color = use_dark_mode ? dark_q2 : light_q2
q3_color = use_dark_mode ? dark_q3 : light_q3
q4_color = use_dark_mode ? dark_q4 : light_q4
q5_color = use_dark_mode ? dark_q5 : light_q5
q6_color = use_dark_mode ? dark_q6 : light_q6
q7_color = use_dark_mode ? dark_q7 : light_q7

border_thickness = input.int(1, title="Border Thickness", minval=1, maxval=10, step=1, tooltip="Set the thickness of the border lines.")
text_size_input = input.string("small", title="Text Size", options=["small", "normal", "large"], group="Display Options")

// Function to determine if the background is dark
is_dark_background() =>
    bg = chart.bg_color
    luma = (0.299 * color.r(bg) + 0.587 * color.g(bg) + 0.114 * color.b(bg)) / 255
    luma < 0.5

// Input for border color
border_color_input = is_dark_background() ? #787b86 : color.new(color.black, 10)

// Timeframe check functions
show5_625MinIntervals_timeframe() =>
    timeframe.in_seconds() <= 120

show22_5MinIntervals_timeframe() =>
    timeframe.in_seconds() <= 540

ishow90MinIntervals_timeframe() =>
    timeframe.in_seconds() <= 2700

is_show6HourCycles_timeframe() => //24 hour
    timeframe.in_seconds() >= 60 and timeframe.in_seconds() <= 21600

is_DailyRanges_timeframe() =>
    timeframe.in_seconds() >= 60 and timeframe.in_seconds() <= 43200

is_WeeklyRanges_timeframe() =>
    timeframe.in_seconds() >= 1800 and timeframe.in_seconds() <= 604800

is_YearlyRanges_timeframe() =>
    timeframe.in_seconds() >= 21600 and timeframe.in_seconds() <= 10368000

is_QuaternaialCycle_timeframe() =>
    timeframe.in_seconds() >= 43200 and timeframe.in_seconds() <= 10368000

is_Tertiary_timeframe() =>
    timeframe.in_seconds() >= 21600 and timeframe.in_seconds() <= 604800

is_225DAY_timeframe() =>
    timeframe.in_seconds() >= 43200 and timeframe.in_seconds() <= 604800

// Automatically determine the appropriate time zone (UTC-4 or UTC-5) based on the time of year
is_dst() =>
    current_year = year(time)

    // Calculate the second Sunday of March
    march_first = timestamp(current_year, 3, 1, 0, 0)
    march_day_of_week = dayofweek(march_first)
    second_sunday_march = 8 + (7 - march_day_of_week + 1) % 7 // Dates 8-14

    // Calculate the first Sunday of November
    november_first = timestamp(current_year, 11, 1, 0, 0)
    november_day_of_week = dayofweek(november_first)
    first_sunday_november = 1 + (7 - november_day_of_week + 1) % 7 // Dates 1-7

    // DST is active if current time is after second Sunday of March and before first Sunday of November
    time >= timestamp(current_year, 3, second_sunday_march, 2, 0) and time < timestamp(current_year, 11, first_sunday_november, 2, 0)

// Offset the time by 6 hours
current_time_adjusted = time + 3600000 // 6 hours in milliseconds

    
is_in_range_90_min(start_hour, start_minute) =>
    start_time = timestamp(year(current_time_adjusted), month(current_time_adjusted), dayofmonth(current_time_adjusted), start_hour, start_minute, 0)
    end_time = start_time + 90 * 60 * 1000
    current_time_adjusted >= start_time and current_time_adjusted < end_time

    
is_in_range_6_hour(start_hour, start_minute, end_hour, end_minute) =>
    start_time = timestamp(year(current_time_adjusted), month(current_time_adjusted), dayofmonth(current_time_adjusted), start_hour, start_minute, 0)
    end_time = timestamp(year(current_time_adjusted), month(current_time_adjusted), dayofmonth(current_time_adjusted), end_hour, end_minute, 0)
    current_time_adjusted >= start_time and current_time_adjusted < end_time

is_in_range_22_5_min(start_hour, start_minute) =>
    start_time = timestamp(year(current_time_adjusted), month(current_time_adjusted), dayofmonth(current_time_adjusted), start_hour, start_minute, 0)
    end_time = start_time + 22.5 * 60 * 1000
    current_time_adjusted >= start_time and current_time_adjusted < end_time

is_in_range_5_625_min(start_hour, start_minute) =>
    start_time = timestamp(year(current_time_adjusted), month(current_time_adjusted), dayofmonth(current_time_adjusted), start_hour, start_minute, 0)
    end_time = start_time + 5.625 * 60 * 1000
    current_time_adjusted >= start_time and current_time_adjusted < end_time

// Function to calculate dynamic y-position based on visible cycles
calculate_y_position(cycle_index) =>
    visible_cycles = array.new_int(0)
    if ShowQuadrennialCyles
        array.push(visible_cycles, 4) // Weekly cycles will use index 1
    if ShowYearlyCyles
        array.push(visible_cycles, 4) // Weekly cycles will use index 1
    if ShowWeeklyCyles
        array.push(visible_cycles, 5) // Weekly cycles will use index 1
    if showDailyCycles
        array.push(visible_cycles, 6) // Daily cycles will use index 2
    if show6HourCycles
        array.push(visible_cycles, 7) // 6 Hour cycles will use index 3
    if show90MinIntervals
        array.push(visible_cycles, 8) // 90 Minute intervals will use index 4
    if show22_5MinIntervals
        array.push(visible_cycles, 9) // 22.5 Minute intervals will use index 5
    if show5_625MinIntervals
        array.push(visible_cycles, 10) // 5.625 Minute intervals will use index 6
        
    
    array.indexof(visible_cycles, cycle_index) + 1

// Updated projection functions
// Define quadrennial cycle ranges and apply labels
cyclerange_quadrennial(start_time, end_time, string textinput, color col) =>
    int y = calculate_y_position(3)  // Adjusting y-position for quadrennial cycle
    box.new(start_time, y, end_time, y - 1, bgcolor=col, text = show_labels ? textinput : "", border_color=color.black, xloc=xloc.bar_time, border_style=line.style_solid, border_width = border_thickness, text_size=text_size_input)

// Function to determine the start and end of each quadrennial cycle
get_quadrennial_start_end(int quadrennial_phase) =>
    var int quad_start = na
    var int quad_end = na
    election_year = 2024  // Next US election year

    if quadrennial_phase == 1
        quad_start := timestamp("GMT-5", election_year - 1, 1, 1, 0)  // Year before US election
        quad_end := timestamp("GMT-5", election_year - 1, 12, 31, 23, 59)  // End of the year before election
    else if quadrennial_phase == 2
        quad_start := timestamp("GMT-5", election_year, 1, 1, 0)  // US election year
        quad_end := timestamp("GMT-5", election_year, 12, 31, 23, 59)  // End of election year
    else if quadrennial_phase == 3
        quad_start := timestamp("GMT-5", election_year + 1, 1, 1, 0)  // Year after US election
        quad_end := timestamp("GMT-5", election_year + 1, 12, 31, 23, 59)  // End of year after election
    else if quadrennial_phase == 4
        quad_start := timestamp("GMT-5", election_year + 2, 1, 1, 0)  // Two years after US election
        quad_end := timestamp("GMT-5", election_year + 2, 12, 31, 23, 59)  // End of two years after election
    [quad_start, quad_end]

// Function to determine the current quadrennial phase
get_quadrennial_phase() =>
    current_year = year(time)
    election_year = 2024  // Set the next US election year

    if current_year == election_year - 1
        1  // Year before the election
    else if current_year == election_year
        2  // US election year
    else if current_year == election_year + 1
        3  // Year after the election
    else if current_year == election_year + 2
        4  // Two years after the election
    else
        na  // No applicable quadrennial phase for other years

// Define quarterly cycle ranges and apply labels
cyclerange_quarterly(start_time, end_time, string textinput, color col) =>
    int y = calculate_y_position(4)  // Adjusting y-position for quarterly cycle
    box.new(start_time, y, end_time, y - 1, bgcolor=col, text = show_labels ? textinput : "", border_color=color.black, xloc=xloc.bar_time, border_style=line.style_solid, border_width = border_thickness, text_size=text_size_input)

// Function to determine the start and end of each quarter
get_quarter_start_end(int quarter_num) =>
    var int quarter_start = na
    var int quarter_end = na
    if quarter_num == 1
        quarter_start := timestamp("GMT-5", year(time), 1, 1, 0)  // January 1st
        quarter_end := timestamp("GMT-5", year(time), 3, 31, 23, 59)  // March 31st
    else if quarter_num == 2
        quarter_start := timestamp("GMT-5", year(time), 4, 1, 0)  // April 1st
        quarter_end := timestamp("GMT-5", year(time), 6, 30, 23, 59)  // June 30th
    else if quarter_num == 3
        quarter_start := timestamp("GMT-5", year(time), 7, 1, 0)  // July 1st
        quarter_end := timestamp("GMT-5", year(time), 9, 30, 23, 59)  // September 30th
    else
        quarter_start := timestamp("GMT-5", year(time), 10, 1, 0)  // October 1st
        quarter_end := timestamp("GMT-5", year(time), 12, 31, 23, 59)  // December 31st
    [quarter_start, quarter_end]


// Define weekly cycle ranges and apply labels
cyclerange_weekly(start_time, end_time, string textinput, color col) =>
    int y = calculate_y_position(5)  // Adjusting y-position for weekly cycle
    box.new(start_time, y, end_time, y - 1, bgcolor=col, text = show_labels ? textinput : "", border_color=color.black, xloc=xloc.bar_time, border_style=line.style_solid, border_width = border_thickness, text_size=text_size_input)

// Function to find the first Friday of the month
get_first_friday() =>
    // Find the day of the week for the 1st of the current month
    day_of_week_on_first = dayofweek(timestamp("GMT-5", year(time), month(time), 1))
    // Calculate how many days to add to reach the first Friday (day 6 in Pine Script's dayofweek function)
    days_to_friday = (6 - day_of_week_on_first + 7) % 7
    // Return the timestamp of the first Friday
    timestamp("GMT-5", year(time), month(time), 1 + days_to_friday, 0)

// Function to determine the start and end of NFP Week
get_nfp_week_start_end() =>
    first_friday = get_first_friday()
    // Start NFP Week at 18:00 on the Sunday before the first Friday
    week_start = timestamp("GMT-5", year(first_friday), month(first_friday), dayofmonth(first_friday) - dayofweek(first_friday) + 1, 18)
    // End NFP Week at 18:00 on the Saturday after the first Friday
    week_end = week_start + 6 * 24 * 60 * 60 * 1000
    [week_start, week_end]

// Function to determine the start and end of subsequent weeks
get_week_start_end(int nfp_week_start, int week_num) =>
    week_start = nfp_week_start + (week_num - 1) * 7 * 24 * 60 * 60 * 1000
    week_end = week_start + 6 * 24 * 60 * 60 * 1000  // Ends on Saturday 18:00
    [week_start, week_end]


// New Daily cycles function
cyclerange_Daily_cycles(condition_start, condition_end, string textinput, color col) =>
    if condition_start and not condition_start[1]
        int y = calculate_y_position(6)
        box.new(time, y, time + (24 * 60 * 60 * 1000), y - 1, bgcolor=col, text = show_labels ? textinput : "", border_color=color.black, xloc=xloc.bar_time, border_style=line.style_solid, border_width = border_thickness, text_size=text_size_input)

// Function to check if the current day and hour are within a specified range
is_in_day_hour_range(day_of_week, start_hour, end_hour) =>
    current_time_ny = timestamp("GMT-7", year, month, dayofmonth, hour, minute, second)  // Set current time in NY timezone
    current_day = dayofweek(current_time_ny) - 1  // Adjust to 0-6 range where 0 is Sunday
    current_hour = hour(current_time_ny)
    current_day == day_of_week and current_hour >= start_hour and current_hour < end_hour

cyclerange_6_hour(condition, string textinput, color col) =>
    if condition and not condition[1]
        int y = calculate_y_position(7)
        box.new(time, y, time + 6 * 60 * 60 * 1000, y - 1, bgcolor=col, text = show_labels ? textinput : "", border_color=color.black, xloc=xloc.bar_time, border_style=line.style_solid, border_width = border_thickness, text_size=text_size_input)

cyclerange_90_min(condition, string textinput, color col) =>
    if condition and not condition[1]
        int y = calculate_y_position(8)
        box.new(time, y, time + 90 * 60 * 1000, y - 1, bgcolor=col, text = show_labels ? textinput : "", border_color=color.black, xloc=xloc.bar_time, border_style=line.style_solid, border_width = border_thickness, text_size=text_size_input)

cyclerange_22_5_min(condition, string textinput, color col) =>
    if condition and not condition[1]
        int y = calculate_y_position(9)
        box.new(time, y, int(time + 22.5 * 60 * 1000), y - 1, bgcolor=col, text = show_labels ? textinput : "", border_color=color.black, xloc=xloc.bar_time, border_style=line.style_solid, border_width = border_thickness, text_size=text_size_input)

cyclerange_5_625_min(condition, string textinput, color col) =>
    if condition and not condition[1]
        int y = calculate_y_position(10)
        box.new(time, y, int(time + 5.1 * 60 * 1000), y - 1, bgcolor=col, text = show_labels ? textinput : "", border_color=color.black, xloc=xloc.bar_time, border_style=line.style_solid, border_width = border_thickness, text_size=text_size_input)


// Function calls for different cycle ranges
if show6HourCycles and is_show6HourCycles_timeframe()
    cyclerange_6_hour(is_in_range_6_hour(0, 0, 6, 0), "Lon", q2_color)
    cyclerange_6_hour(is_in_range_6_hour(6, 0, 12, 0), "AM", q3_color)
    cyclerange_6_hour(is_in_range_6_hour(12, 0, 18, 0), "PM", q4_color)
    cyclerange_6_hour(is_in_range_6_hour(18, 0, 24, 0), "Asia", q1_color)


if show90MinIntervals and ishow90MinIntervals_timeframe()
    cyclerange_90_min(is_in_range_90_min(0, 0),"Q1",q1_color)
    cyclerange_90_min(is_in_range_90_min(1, 30),"Q2", q2_color)
    cyclerange_90_min(is_in_range_90_min(3, 0),"Q3", q3_color)
    cyclerange_90_min(is_in_range_90_min(4, 30),"Q4", q4_color)
    cyclerange_90_min(is_in_range_90_min(6, 0),"Q1",q1_color)
    cyclerange_90_min(is_in_range_90_min(7, 30),"Q2", q2_color)
    cyclerange_90_min(is_in_range_90_min(9, 0),"Q3", q3_color)
    cyclerange_90_min(is_in_range_90_min(10, 30),"Q4", q4_color)
    cyclerange_90_min(is_in_range_90_min(12, 0),"Q1",q1_color)
    cyclerange_90_min(is_in_range_90_min(13, 30),"Q2", q2_color)
    cyclerange_90_min(is_in_range_90_min(15, 0),"Q3", q3_color)
    cyclerange_90_min(is_in_range_90_min(16, 30),"Q4", q4_color)
    cyclerange_90_min(is_in_range_90_min(18, 0),"Q1",q1_color)
    cyclerange_90_min(is_in_range_90_min(19, 30),"Q2", q2_color)
    cyclerange_90_min(is_in_range_90_min(21, 0),"Q3", q3_color)
    cyclerange_90_min(is_in_range_90_min(22, 30),"Q4", q4_color)

if show22_5MinIntervals and show22_5MinIntervals_timeframe()
    cyclerange_22_5_min(is_in_range_22_5_min(0, 0),"Q1",q1_color)      // 00:00 to 00:22.5
    cyclerange_22_5_min(is_in_range_22_5_min(0, 22), "Q2", q2_color)     // 00:22.5 to 00:45
    cyclerange_22_5_min(is_in_range_22_5_min(0, 45), "Q3", q3_color)      // 00:45 to 01:07.5
    cyclerange_22_5_min(is_in_range_22_5_min(1, 7), "Q4", q4_color)     // 01:07.5 to 01:30
    cyclerange_22_5_min(is_in_range_22_5_min(1, 30),"Q1",q1_color)     // 01:30 to 01:52.5
    cyclerange_22_5_min(is_in_range_22_5_min(1, 52), "Q2", q2_color)     // 01:52.5 to 02:15
    cyclerange_22_5_min(is_in_range_22_5_min(2, 15), "Q3", q3_color)     // 02:15 to 02:37.5
    cyclerange_22_5_min(is_in_range_22_5_min(2, 37), "Q4", q4_color)    // 02:37.5 to 03:00
    cyclerange_22_5_min(is_in_range_22_5_min(3, 0),"Q1",q1_color)      // 03:00 to 03:22.5
    cyclerange_22_5_min(is_in_range_22_5_min(3, 22), "Q2", q2_color)     // 03:22.5 to 03:45
    cyclerange_22_5_min(is_in_range_22_5_min(3, 45), "Q3", q3_color)     // 03:45 to 04:07.5
    cyclerange_22_5_min(is_in_range_22_5_min(4, 7), "Q4", q4_color)     // 04:07.5 to 04:30
    cyclerange_22_5_min(is_in_range_22_5_min(4, 30),"Q1",q1_color)     // 04:30 to 04:52.5
    cyclerange_22_5_min(is_in_range_22_5_min(4, 52), "Q2", q2_color)     // 04:52.5 to 05:15
    cyclerange_22_5_min(is_in_range_22_5_min(5, 15), "Q3", q3_color)     // 05:15 to 05:37.5
    cyclerange_22_5_min(is_in_range_22_5_min(5, 37), "Q4", q4_color)    // 05:37.5 to 06:00
    cyclerange_22_5_min(is_in_range_22_5_min(6, 0),"Q1",q1_color)      // 06:00 to 06:22.5
    cyclerange_22_5_min(is_in_range_22_5_min(6, 22), "Q2", q2_color)     // 06:22.5 to 06:45
    cyclerange_22_5_min(is_in_range_22_5_min(6, 45), "Q3", q3_color)     // 06:45 to 07:07.5
    cyclerange_22_5_min(is_in_range_22_5_min(7, 7), "Q4", q4_color)     // 07:07.5 to 07:30
    cyclerange_22_5_min(is_in_range_22_5_min(7, 30),"Q1",q1_color)     // 07:30 to 07:52.5
    cyclerange_22_5_min(is_in_range_22_5_min(7, 52), "Q2", q2_color)     // 07:52.5 to 08:15
    cyclerange_22_5_min(is_in_range_22_5_min(8, 15), "Q3", q3_color)     // 08:15 to 08:37.5
    cyclerange_22_5_min(is_in_range_22_5_min(8, 37), "Q4", q4_color)    // 08:37.5 to 09:00
    cyclerange_22_5_min(is_in_range_22_5_min(9, 0),"Q1",q1_color)      // 09:00 to 09:22.5
    cyclerange_22_5_min(is_in_range_22_5_min(9, 22), "Q2", q2_color)     // 09:22.5 to 09:45
    cyclerange_22_5_min(is_in_range_22_5_min(9, 45), "Q3", q3_color)     // 09:45 to 10:07.5
    cyclerange_22_5_min(is_in_range_22_5_min(10, 7), "Q4", q4_color)    // 10:07.5 to 10:30
    cyclerange_22_5_min(is_in_range_22_5_min(10, 30),"Q1",q1_color)    // 10:30 to 10:52.5
    cyclerange_22_5_min(is_in_range_22_5_min(10, 52), "Q2", q2_color)    // 10:52.5 to 11:15
    cyclerange_22_5_min(is_in_range_22_5_min(11, 15), "Q3", q3_color)    // 11:15 to 11:37.5
    cyclerange_22_5_min(is_in_range_22_5_min(11, 37), "Q4", q4_color)   // 11:37.5 to 12:00
    cyclerange_22_5_min(is_in_range_22_5_min(12, 0),"Q1",q1_color)     // 12:00 to 12:22.5
    cyclerange_22_5_min(is_in_range_22_5_min(12, 22), "Q2", q2_color)    // 12:22.5 to 12:45
