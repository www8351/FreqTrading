    cyclerange_22_5_min(is_in_range_22_5_min(13, 7), "Q4", q4_color)    // 01:07.5 to 01:30
    cyclerange_22_5_min(is_in_range_22_5_min(13, 30),"Q1",q1_color)    // 01:30 to 01:52.5
    cyclerange_22_5_min(is_in_range_22_5_min(13, 52), "Q2", q2_color)    // 01:52.5 to 02:15 
    cyclerange_22_5_min(is_in_range_22_5_min(14, 15), "Q3", q3_color)    // 02:15 to 02:37.5
    cyclerange_22_5_min(is_in_range_22_5_min(14, 37), "Q4", q4_color)   // 02:37.5 to 03:00
    cyclerange_22_5_min(is_in_range_22_5_min(15, 0),"Q1",q1_color)     // 03:00 to 03:22.5
    cyclerange_22_5_min(is_in_range_22_5_min(15, 22), "Q2", q2_color)    // 03:22.5 to 03:45
    cyclerange_22_5_min(is_in_range_22_5_min(15, 45), "Q3", q3_color)    // 03:45 to 04:07.5
    cyclerange_22_5_min(is_in_range_22_5_min(16, 7), "Q4", q4_color)    // 04:07.5 to 04:30
    cyclerange_22_5_min(is_in_range_22_5_min(16, 30),"Q1",q1_color)    // 04:30 to 04:52.5
    cyclerange_22_5_min(is_in_range_22_5_min(16, 52), "Q2", q2_color)    // 04:52.5 to 05:15
    cyclerange_22_5_min(is_in_range_22_5_min(17, 15), "Q3", q3_color)    // 05:15 to 05:37.5
