// Add Daily cycles
// Add Daily cycles
if showDailyCycles and is_DailyRanges_timeframe()

    cyclerange_Daily_cycles(is_in_day_hour_range(0, 18, 24) or is_in_day_hour_range(1, 0, 18),is_in_day_hour_range(1, 18, 24) or is_in_day_hour_range(2, 0, 18),"Mon", q1_color)

    cyclerange_Daily_cycles(is_in_day_hour_range(1, 18, 24) or is_in_day_hour_range(2, 0, 18),is_in_day_hour_range(2, 18, 24) or is_in_day_hour_range(3, 0, 18),"Tue", q2_color)

    cyclerange_Daily_cycles(is_in_day_hour_range(2, 18, 24) or is_in_day_hour_range(3, 0, 18),is_in_day_hour_range(3, 18, 24) or is_in_day_hour_range(4, 0, 18),"Wed", q3_color)

    cyclerange_Daily_cycles(is_in_day_hour_range(3, 18, 24) or is_in_day_hour_range(4, 0, 18),is_in_day_hour_range(4, 18, 24) or is_in_day_hour_range(5, 0, 18),"Thu", q4_color)

// Check which week it is and apply corresponding color and label
if is_WeeklyRanges_timeframe() and ShowWeeklyCyles
    // Get the start and end of NFP Week (Week 1)
    [nfp_week_start, nfp_week_end] = get_nfp_week_start_end()

    // Week 1 (NFP Week)
    cyclerange_weekly(nfp_week_start, nfp_week_end, "NFP Week", q1_color) // Using index 1

    // Week 2
    [week2_start, week2_end] = get_week_start_end(nfp_week_start, 2)
    cyclerange_weekly(week2_start, week2_end, "Week 2", q2_color) // Using index 2

    // Week 3
    [week3_start, week3_end] = get_week_start_end(nfp_week_start, 3)
    cyclerange_weekly(week3_start, week3_end, "Week 3", q3_color) // Using index 3

    // Week 4
    [week4_start, week4_end] = get_week_start_end(nfp_week_start, 4)
    cyclerange_weekly(week4_start, week4_end, "Week 4", q4_color) // Using index 4


// Check which quarter it is and apply corresponding color and label
if is_YearlyRanges_timeframe() and ShowYearlyCyles
    // Get the start and end times for each quarter
    [q1_start, q1_end] = get_quarter_start_end(1)
    [q2_start, q2_end] = get_quarter_start_end(2)
    [q3_start, q3_end] = get_quarter_start_end(3)
    [q4_start, q4_end] = get_quarter_start_end(4)

    // Q1: January 1 to March 31
    cyclerange_quarterly(q1_start, q1_end, "Q1", q1_color)

    // Q2: April 1 to June 30
    cyclerange_quarterly(q2_start, q2_end, "Q2", q2_color)

    // Q3: July 1 to September 30
    cyclerange_quarterly(q3_start, q3_end, "Q3", q3_color)

    // Q4: October 1 to December 31
    cyclerange_quarterly(q4_start, q4_end, "Q4", q4_color)



// Check and display quadrennial cycle ranges
if is_YearlyRanges_timeframe() and ShowQuadrennialCyles
    quad_phase = get_quadrennial_phase()
    
    // Get the start and end times for each quadrennial phase
    [quad_start, quad_end] = get_quadrennial_start_end(quad_phase)

    // Display the appropriate quadrennial phase on the chart
    if quad_phase == 1
        cyclerange_quadrennial(quad_start, quad_end, "Quadrennial Q1: Year Before Election", q1_color)
    if quad_phase == 2
        cyclerange_quadrennial(quad_start, quad_end, "Quadrennial Q2: US Election Year", q2_color)
    if quad_phase == 3
        cyclerange_quadrennial(quad_start, quad_end, "Quadrennial Q3: Year After Election", q3_color)
    if quad_phase == 4
        cyclerange_quadrennial(quad_start, quad_end, "Quadrennial Q4: Two Years After Election", q4_color)