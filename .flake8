[flake8]
max-line-length = 100
# E203 (whitespace before ':') and W503 (line break before binary operator)
# conflict with black's formatting; both are black-recommended ignores.
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    data,
    log_backups,
    .obsidian
